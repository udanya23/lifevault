# LifeVault Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ======================
# SERVER
# ======================
NODE_ENV=development
PORT=5000
# Frontend origin (CORS + email links). No trailing slash.
# Local:
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Production (Render) — set these on the Render backend service (not localhost):
# CLIENT_URL=https://lifevault-frontend-9t3i.onrender.com
# FRONTEND_URL=https://lifevault-frontend-9t3i.onrender.com

# ======================
# DATABASE
# ======================
# LifeVault accepts MONGODB_URI or MONGODB_URL
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/lifevault?retryWrites=true&w=majority

# ======================
# JWT
# ======================
JWT_ACCESS_SECRET=your_super_secret_jwt_access_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_change_this_in_production
# Legacy aliases also supported: JWT_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REMEMBER_ME_EXPIRES_IN=30d

# ======================
# EMAIL — Gmail App Password (recommended for dev)
# ======================
EMAIL_SERVICE=gmail
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
# Legacy alias: EMAIL_PASSWORD
EMAIL_FROM_NAME=LifeVault
EMAIL_FROM_ADDRESS=your_gmail@gmail.com

# Or use Mailtrap / SMTP instead:
# EMAIL_HOST=sandbox.smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_USER=your_mailtrap_user
# EMAIL_PASS=your_mailtrap_password

# For Production (SendGrid):
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=your_sendgrid_api_key

# ======================
# CLOUDINARY
# ======================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ======================
# SECURITY
# ======================
BCRYPT_SALT_ROUNDS=12
# Secret code required to register an admin account from the register page.
# Share only with trusted people. Leave empty to disable admin self-registration.
ADMIN_REGISTRATION_CODE=change_this_secret_admin_code
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ======================
# APP
# ======================
APP_NAME=LifeVault
APP_URL=http://localhost:5000

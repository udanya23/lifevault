# LifeVault Frontend Environment Variables
# Copy to .env.local for local development

# API base URL — use /api/v1 when nginx/docker proxies to backend
# For local dev with Vite proxy, leave as default or omit entirely
VITE_API_URL=/api/v1

# Render / production (frontend Static Site + separate API Web Service):
# Set this at BUILD time on Render. Replace with your real API URL:
# VITE_API_URL=https://lifevault-api-xxxx.onrender.com/api/v1

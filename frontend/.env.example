# LifeVault Frontend Environment Variables
# Copy to .env.local for local development overrides

# ── Local development (recommended) ──────────────────────────────────────────
# Vite proxy forwards /api to http://localhost:5000 — keep this for local work:
VITE_API_URL=/api/v1

# Direct local backend (optional alternative):
# VITE_API_URL=http://localhost:5000/api/v1

# ── Production / Render (used in .env.production) ────────────────────────────
# VITE_API_URL=https://lifevault-backend-4iip.onrender.com/api/v1
